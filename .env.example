# nNmori - Environment Variables
# Copy this file to .env and fill in your values

# JWT Secret (REQUIRED - Change in production!)
JWT_SECRET=dev-secret-do-not-use-in-production

# Database (PostgreSQL)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS allowed origins (comma-separated, leave empty to allow all in dev)
# Capacitor origins (https://localhost, capacitor://localhost) are always included.
# e.g. https://app.numori.app
CORS_ORIGINS=

# SMTP (for email verification & password recovery)
# Leave SMTP_HOST empty to log emails to console instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@numori.app

# API Base URL (leave empty for web, set for native Capacitor builds)
# e.g. https://app.numori.app
NUXT_PUBLIC_API_BASE=

# Store links for native app update notifications
# When a new version is detected on native, users are directed to the store
NUXT_PUBLIC_STORE_ANDROID=
NUXT_PUBLIC_STORE_IOS=
