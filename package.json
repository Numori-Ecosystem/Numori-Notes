{
  "name": "numori",
  "type": "module",
  "private": true,
  "version": "0.5.0",
  "description": "Free, open-source notes app with a built-in natural language calculator. Do math as you write, export to multiple formats, and sync with end-to-end encryption.",
  "authors": [
    {
      "name": "Erik Bjerke",
      "email": "contact@erikbjerke.com",
      "url": "https://erikbjerke.com"
    },
    {
      "name": "TheProcedural Software Ltd",
      "email": "contact@theprocedural.com",
      "url": "https://theprocedural.com"
    }
  ],
  "license": "AGPL-3.0",
  "homepage": "https://github.com/Erik-Bjerke/Numori",
  "repository": {
    "type": "git",
    "url": "https://github.com/Erik-Bjerke/Numori.git"
  },
  "keywords": [
    "calculator",
    "notepad",
    "natural-language",
    "markdown",
    "open-source",
    "pwa",
    "vue",
    "nuxt"
  ],
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:stop": "docker compose -f docker-compose.dev.yml down",
    "dev:full": "docker compose -f docker-compose.dev.yml up -d && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "bcryptjs": "^3.0.3",
    "dexie": "^4.4.2",
    "highlight.js": "^11.11.1",
    "nuxt": "^4.4.2",
    "nuxt-codemirror": "^0.0.20",
    "nuxt-i18n-micro": "^3.17.0",
    "pg": "^8.20.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "vitest": "^4.1.2"
  }
}
