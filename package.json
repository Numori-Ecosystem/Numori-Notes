{
  "name": "numori-notes",
  "type": "module",
  "private": true,
  "version": "0.18.0",
  "description": "Free, open-source notes app with a built-in natural language calculator. Do math as you write, export to multiple formats, and sync with end-to-end encryption.",
  "authors": [
    {
      "name": "Erik Bjerke",
      "email": "contact@erikbjerke.com",
      "url": "https://erikbjerke.com"
    },
    {
      "name": "TheProcedural Software Ltd",
      "email": "contact@theprocedural.com",
      "url": "https://theprocedural.com"
    }
  ],
  "collaborators": [
    {
      "name": "Yaiza Wadhwani Valderas",
      "email": "yaizawv@proton.me"
    }
  ],
  "license": "AGPL-3.0",
  "homepage": "https://github.com/Numori-Ecosystem/Numori-Notes",
  "repository": {
    "type": "git",
    "url": "git@github.com:Numori-Ecosystem/Numori-Notes.git"
  },
  "keywords": [
    "calculator",
    "notepad",
    "natural-language",
    "markdown",
    "open-source",
    "pwa",
    "vue",
    "nuxt"
  ],
  "scripts": {
    "build": "nuxt build",
    "build:app": "nuxt generate && npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "open": "npx cap open android && npx cap open ios",
    "dev": "concurrently -n web,android,ios -c blue,green,yellow \"npm run dev:web\" \"npm run _cap:android\" \"npm run _cap:ios\"",
    "dev:web": "rm -f public/version.json public/sw.js && nuxt cleanup && nuxt dev --host 0.0.0.0",
    "dev:android": "concurrently -n web,android -c blue,green \"npm run dev:web\" \"npm run _cap:android\"",
    "dev:ios": "concurrently -n web,ios -c blue,yellow \"npm run dev:web\" \"npm run _cap:ios\"",
    "dev:phones": "concurrently -n web,android,ios -c blue,green,yellow \"npm run dev:web\" \"npm run _cap:android\" \"npm run _cap:ios\"",
    "_cap:android": "nuxt generate && npx cap sync android && npx cap run android -l --port 3000",
    "_cap:ios": "nuxt generate && npx cap sync ios && npx cap run ios -l --port 3000",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:stop": "docker compose -f docker-compose.dev.yml down",
    "dev:full": "docker compose -f docker-compose.dev.yml up -d && npm run dev:web",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/privacy-screen": "^2.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-native-biometric": "^8.4.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "bcryptjs": "^3.0.3",
    "dexie": "^4.4.2",
    "highlight.js": "^11.11.1",
    "nodemailer": "^8.0.5",
    "nuxt": "^4.4.2",
    "nuxt-codemirror": "^0.0.20",
    "pg": "^8.20.0",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.4"
  }
}
